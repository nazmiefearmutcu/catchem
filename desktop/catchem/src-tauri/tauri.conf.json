{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Catchem",
  "version": "0.1.0",
  "identifier": "com.fusionstack.catchem",
  "build": {
    "frontendDist": "../web/dist",
    "devUrl": "http://localhost:1421",
    "beforeDevCommand": "npm --prefix ../web run dev",
    "beforeBuildCommand": "npm --prefix ../web run build"
  },
  "app": {
    "withGlobalTauri": true,
    "macOSPrivateApi": true,
    "windows": [
      {
        "label": "main",
        "title": "Catchem",
        "width": 1280,
        "height": 820,
        "minWidth": 980,
        "minHeight": 640,
        "fullscreen": false,
        "resizable": true,
        "decorations": true,
        "titleBarStyle": "Visible",
        "transparent": false,
        "alwaysOnTop": false,
        "center": true
      }
    ],
    "security": {
      "csp": "default-src 'self' http://127.0.0.1:8087; script-src 'self' 'unsafe-inline' http://127.0.0.1:8087; style-src 'self' 'unsafe-inline'; connect-src 'self' http://127.0.0.1:8087 ws://127.0.0.1:8087; img-src 'self' data: http://127.0.0.1:8087; font-src 'self' data:; object-src 'none'; frame-ancestors 'none'; base-uri 'self'",
      "freezePrototype": true
    }
  },
  "bundle": {
    "active": true,
    "category": "Productivity",
    "copyright": "Copyright © 2026 fusion_stack",
    "targets": ["app", "dmg"],
    "shortDescription": "Catchem — local-first news-to-finance analyst workstation",
    "longDescription": "Catchem wraps the local fusion_stack pipeline in a polished macOS desktop UI. Paste a news article, upload a text file, and watch the same finance-relevance pipeline process it locally. NewsImpact stays quarantined; production-safe mode is the default.",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "minimumSystemVersion": "12.0",
      "hardenedRuntime": true,
      "entitlements": "./Entitlements.plist"
    },
    "resources": [],
    "externalBin": []
  },
  "plugins": {
    "shell": { "open": "^https?://" },
    "notification": { "all": true },
    "dialog": { "open": true, "save": true },
    "fs": { "scope": ["$APPDATA/*", "$DOCUMENT/*", "$DOWNLOAD/*"] },
    "opener": {}
  }
}
