# fusion_stack environment example. Copy to .env and edit. All values are optional.

# ─── Mode ─────────────────────────────────────────────────────────────────────
# One of: production_safe | replay_existing | live_tail | research_diagnostic
FUSION_MODE=production_safe

# ─── Repo locations ───────────────────────────────────────────────────────────
AWARENESS_REPO_PATH=/Users/nazmi/Desktop/Projeler/proje/awareness
NEWSIMPACT_REPO_PATH=/Users/nazmi/Desktop/Projeler/proje/merged_news
AWARENESS_DATA_DIR=/Users/nazmi/Desktop/Projeler/proje/awareness/data
FUSION_OUTPUT_DIR=/Users/nazmi/Desktop/Projeler/proje/fusion_stack/data

# ─── Models (Hugging Face IDs) ────────────────────────────────────────────────
FUSION_SENTIMENT_MODEL=ProsusAI/finbert
FUSION_ZERO_SHOT_MODEL=facebook/bart-large-mnli
FUSION_EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
FUSION_RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L6-v2

# ─── Optional ─────────────────────────────────────────────────────────────────
# DO NOT enable this flag in production_safe mode. Diagnostic only.
FUSION_ENABLE_NEWSIMPACT_DIAGNOSTIC=false

# Skip ML model loading (use deterministic stubs). Useful for CPU-only smoke tests.
FUSION_USE_ML_STUBS=true

# Kaggle (optional — leave blank to skip dataset downloads)
KAGGLE_USERNAME=
KAGGLE_KEY=

# ─── Service ──────────────────────────────────────────────────────────────────
FUSION_API_HOST=127.0.0.1
FUSION_API_PORT=8087
FUSION_LOG_LEVEL=INFO
