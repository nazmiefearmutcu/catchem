{
  "$schema": "../../../../../../../../.schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Catchem default capability set. Locked to localhost API + filesystem dialogs.",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:window:default",
    "core:webview:default",
    "core:app:default",
    "core:menu:default",
    "core:resources:default",
    "core:event:default",
    "shell:allow-open",
    "dialog:default",
    "dialog:allow-open",
    "fs:allow-read-text-file",
    "notification:default",
    "notification:allow-notify",
    "opener:default",
    "opener:allow-open-url",
    "process:default"
  ]
}
