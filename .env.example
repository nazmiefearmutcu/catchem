# catchem environment example. Copy to .env and edit. All values are optional.
#
# Env var naming contract (enforced by pydantic-settings):
#   • Prefix:   CATCHEM_
#   • Nested:   __ (double underscore) between the model and the field.
#   • Top-level fields use the prefix alone (e.g. CATCHEM_MODE).
# A single-underscore form like `CATCHEM_API_HOST` looks similar but is
# silently ignored — see tests/test_settings_live_env_override.py for the
# regression that pins this contract.

# ─── Mode ─────────────────────────────────────────────────────────────────────
# Top-level Settings.mode field → prefix-only.
# One of: production_safe | replay_existing | live_tail | research_diagnostic
CATCHEM_MODE=production_safe

# ─── Repo locations (Settings.paths.*) ───────────────────────────────────────
CATCHEM_PATHS__AWARENESS_REPO=/Users/nazmi/Desktop/Projeler/proje/awareness
CATCHEM_PATHS__NEWSIMPACT_REPO=/Users/nazmi/Desktop/Projeler/proje/merged_news
CATCHEM_PATHS__AWARENESS_DATA_DIR=/Users/nazmi/Desktop/Projeler/proje/awareness/data
CATCHEM_PATHS__CATCHEM_OUTPUT_DIR=/Users/nazmi/Desktop/Projeler/proje/catchem/data

# ─── Models (Settings.models.* — Hugging Face IDs) ───────────────────────────
CATCHEM_MODELS__SENTIMENT_DEFAULT=ProsusAI/finbert
CATCHEM_MODELS__ZERO_SHOT=facebook/bart-large-mnli
CATCHEM_MODELS__EMBEDDING=sentence-transformers/all-MiniLM-L6-v2
CATCHEM_MODELS__RERANKER=cross-encoder/ms-marco-MiniLM-L6-v2

# ─── Guards (Settings.guards.*) ──────────────────────────────────────────────
# DO NOT enable this flag in production_safe mode. Diagnostic only.
CATCHEM_GUARDS__NEWSIMPACT_DIAGNOSTIC_ENABLED=false

# ─── Convenience flat override (Settings.use_ml_stubs) ───────────────────────
# Skip ML model loading (use deterministic stubs). Useful for CPU-only smoke
# tests. This is the ONE intentional flat (no-`__`) env var — wired by the
# `_propagate_flat_overrides` validator into Settings.models.use_ml_stubs.
CATCHEM_USE_ML_STUBS=true

# Kaggle (optional — leave blank to skip dataset downloads).
# These are NOT consumed by Settings; the Kaggle CLI reads them directly.
KAGGLE_USERNAME=
KAGGLE_KEY=

# ─── Service (Settings.api.*, Settings.logging.*) ────────────────────────────
CATCHEM_API__HOST=127.0.0.1
CATCHEM_API__PORT=8087
CATCHEM_LOGGING__LEVEL=INFO
